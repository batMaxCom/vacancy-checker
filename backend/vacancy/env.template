# POSTGRESQL CONFIGURATION
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=new_db

# STARTUP CONFIGURATION
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
OPENAPI_URL=/swagger/docs/v1.0/project
DOCS_URL=/docs

# KAFKA
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=ccheck

# Consumer group
KAFKA_GROUP_ID=vacancy-service

# Offset handling
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false

# Consumer liveness
KAFKA_SESSION_TIMEOUT_MS=45000
KAFKA_HEARTBEAT_INTERVAL_MS=15000

# Network
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_SOCKET_TIMEOUT_MS=30000

# Poll
KAFKA_POLL_TIMEOUT_SECONDS=1

# Reconnect
KAFKA_RECONNECT_ATTEMPTS=10
KAFKA_RECONNECT_INITIAL_DELAY_SECONDS=1
KAFKA_RECONNECT_MAX_DELAY_SECONDS=60

# AUTH CONFIGURATION
AUTHENTICATE_URL=http://localhost:8003/auth
# ============================================
# PostgreSQL (global)
# ============================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=54331
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=postgres

# ============================================
# Vacancy service
# ============================================
SERVER_EXTERNAL_PORT=8001
SERVER_HOST=0.0.0.0
SERVER_PORT=80
OPENAPI_URL=/swagger/docs/v1.0/
DOCS_URL=/docs
LOOP=auto
PAGE_SIZE=10

# ============================================
# Search service
# ============================================
# SERVER_EXTERNAL_PORT=8000
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# OPENAPI_URL=/swagger/docs/v1.0/project
# DOCS_URL=/docs
# LOOP=auto

# ============================================
# Kafka (search broker)
# ============================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=ccheck-service
KAFKA_ACKS=all
KAFKA_ENABLE_IDEMPOTENCE=true
KAFKA_RETRIES=10
KAFKA_RETRY_BACKOFF_MS=1000
KAFKA_DELIVERY_TIMEOUT_MS=120000
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_SOCKET_TIMEOUT_MS=30000
KAFKA_LINGER_MS=5
KAFKA_BATCH_SIZE=16384
KAFKA_COMPRESSION_TYPE=snappy

# ============================================
# Kafka (vacancy consumer)
# ============================================
KAFKA_GROUP_ID=app-consumer-group
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false
KAFKA_SESSION_TIMEOUT_MS=45000
KAFKA_HEARTBEAT_INTERVAL_MS=15000
KAFKA_POLL_TIMEOUT_SECONDS=1
KAFKA_RECONNECT_ATTEMPTS=10
KAFKA_RECONNECT_INITIAL_DELAY_SECONDS=1
KAFKA_RECONNECT_MAX_DELAY_SECONDS=60

# ============================================
# Frontend (Vite)
# ============================================
VITE_SEARCH_API=http://localhost:8000
VITE_VACANCY_API=http://localhost:8001
